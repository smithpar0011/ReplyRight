# Copy this file to .env.local and fill in your keys

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google OAuth — https://console.cloud.google.com/
# Create a Web Application credential, add redirect URI:
#   http://localhost:3000/api/auth/callback  (dev)
#   https://yourdomain.com/api/auth/callback  (prod)
# Enable: "Google Business Profile API" in the API Library
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Base URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
